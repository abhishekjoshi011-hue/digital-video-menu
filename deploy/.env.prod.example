# Mongo root credentials
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=change_me_root

# App Mongo credentials (create this user in Mongo admin DB)
MONGO_APP_USERNAME=menu_app
MONGO_APP_PASSWORD=change_me_app
MONGO_DB_NAME=restaurant_db

# Security secrets (base64-encoded random strings)
APP_JWT_SECRET=replace_with_base64_secret_min_32_bytes
APP_QR_SECRET=replace_with_base64_secret_min_32_bytes
APP_AUTH_SETUP_KEY=replace_with_onboarding_key
APP_AUTH_ALLOW_PUBLIC_REGISTRATION=false

# Public URLs
APP_PUBLIC_MENU_BASE_URL=https://menu.yourdomain.com
VITE_API_BASE_URL=https://api.yourdomain.com
VITE_TENANT_ID=demo-restaurant

# Ops defaults
APP_ORDERS_SLA_MINUTES=20

# Forecast ML service
APP_FORECAST_ML_ENABLED=true
APP_FORECAST_ML_URL=http://forecast_ml:8001/predict
